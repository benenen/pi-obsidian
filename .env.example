# Obsidian Local REST API connection.
# Copy to `.env` (or export in your shell) and fill in your own values.

# Base URL of the Obsidian Local REST API plugin (HTTP endpoint).
OBSIDIAN_API_URL=http://127.0.0.1:27123

# API key from the Local REST API plugin settings (sent as `Bearer <key>`).
# Find it in Obsidian → Settings → Local REST API.
OBSIDIAN_API_KEY=your-obsidian-api-key-here
